{
  "name": "nuke",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "npx prisma db push",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma db push --force-reset && npm run db:seed",
    "preflight:email": "node --import tsx scripts/email-preflight.ts",
    "smoke:email": "node --import tsx scripts/email-smoke-test.ts",
    "smoke:form": "node --import tsx scripts/form-foundation-smoke.ts",
    "smoke:p3c4": "node --import tsx scripts/p3c4-assisted-smoke.ts",
    "smoke:p3c5": "node --import tsx scripts/p3c5-challenge-smoke.ts",
    "automation:install-browser": "npx playwright install chromium"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "jose": "^6.0.0",
    "next": "16.2.2",
    "playwright": "^1.59.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^6.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
